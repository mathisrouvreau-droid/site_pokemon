rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Listings — lecture publique, écriture admin seulement
    match /listings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders — lecture/écriture pour l'utilisateur concerné + admin
    match /orders/{doc} {
      allow read: if request.auth != null && (resource.data.email == request.auth.token.email || isAdmin());
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Users — lecture/écriture pour son propre profil
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Admins — lecture/écriture admin seulement
    match /admins/{doc} {
      allow read, write: if isAdmin();
    }

    // Wishlist — lecture/écriture pour l'utilisateur concerné
    match /wishlist/{doc} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.email == request.auth.token.email;
    }

    // Expenses — admin seulement
    match /expenses/{doc} {
      allow read, write: if isAdmin();
    }

    // Notifications — lecture pour l'utilisateur, écriture admin
    match /notifications/{doc} {
      allow read: if request.auth != null && resource.data.email == request.auth.token.email;
      allow write: if isAdmin();
    }

    // Helper: check if current user is admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
