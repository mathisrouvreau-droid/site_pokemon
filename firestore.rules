rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══ DENY ALL by default ═══
    match /{document=**} {
      allow read, write: if false;
    }

    // Listings — lecture publique, écriture admin seulement
    match /listings/{doc} {
      allow read: if true;
      allow delete: if isAdmin();
      allow create, update: if isAdmin()
        && request.resource.data.keys().hasAll(['name', 'price'])
        && request.resource.data.name is string
        && request.resource.data.price is number
        && request.resource.data.price >= 0;
    }

    // Orders — lecture pour l'utilisateur concerné + admin
    match /orders/{doc} {
      allow read: if request.auth != null && (resource.data.email == request.auth.token.email || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.keys().hasAll(['email', 'items', 'total']);
      allow update, delete: if isAdmin();
    }

    // Checkout sessions — créées par Cloud Functions, lecture pour l'utilisateur
    match /checkout_sessions/{doc} {
      allow read: if request.auth != null && resource.data.email == request.auth.token.email;
      allow write: if false; // Cloud Functions only
    }

    // Support tickets
    match /support_tickets/{doc} {
      allow read: if request.auth != null && (resource.data.email == request.auth.token.email || isAdmin());
      allow create: if request.auth != null
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.keys().hasAll(['email', 'subject', 'message'])
        && request.resource.data.subject is string
        && request.resource.data.subject.size() <= 200
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 5000;
      allow update: if request.auth != null && (resource.data.email == request.auth.token.email || isAdmin());
      allow delete: if isAdmin();
    }

    // Users — lecture/écriture pour son propre profil uniquement
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['role', 'isAdmin', 'admin']);
    }

    // Admins — un admin peut gérer les autres admins
    // Un utilisateur authentifié peut créer son propre doc admin (bootstrap)
    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId || isAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    // Wishlist
    match /wishlist/{doc} {
      allow read: if request.auth != null && resource.data.email == request.auth.token.email;
      allow create: if request.auth != null
        && request.resource.data.email == request.auth.token.email;
      allow delete: if request.auth != null && resource.data.email == request.auth.token.email;
    }

    // Expenses — admin seulement
    match /expenses/{doc} {
      allow read, write: if isAdmin();
    }

    // Notifications
    match /notifications/{doc} {
      allow read: if request.auth != null && resource.data.email == request.auth.token.email;
      allow write: if isAdmin();
    }

    // Promo codes — lecture publique, écriture admin
    match /promo_codes/{doc} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.data.keys().hasAll(['code', 'percent', 'active'])
        && request.resource.data.percent is number
        && request.resource.data.percent >= 1
        && request.resource.data.percent <= 100;
    }

    // Custom sets — lecture publique, écriture admin
    match /custom_sets/{doc} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.data.keys().hasAll(['name'])
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 200;
    }

    // Settings (announcements, marquee) — lecture publique, écriture admin
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Helper: check if current user is admin
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
